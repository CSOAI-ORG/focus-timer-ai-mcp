{
  "name": "focus-timer-ai-mcp",
  "description": "Focus Timer Ai automation via MCP. Includes start focus, pause focus, resume focus. By MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "start_focus",
      "description": "Start a new focus timer session",
      "parameters": {
        "type": "object",
        "properties": {
          "minutes": {
            "type": "integer"
          },
          "task": {
            "type": "string"
          }
        },
        "required": []
      }
    },
    {
      "name": "pause_focus",
      "description": "Pause the current focus session",
      "parameters": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string"
          }
        },
        "required": [
          "session_id"
        ]
      }
    },
    {
      "name": "resume_focus",
      "description": "Resume a paused focus session",
      "parameters": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string"
          }
        },
        "required": [
          "session_id"
        ]
      }
    },
    {
      "name": "end_focus",
      "description": "End a focus session early",
      "parameters": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string"
          },
          "completed": {
            "type": "boolean"
          }
        },
        "required": [
          "session_id"
        ]
      }
    },
    {
      "name": "get_sessions",
      "description": "Get all focus sessions with stats",
      "parameters": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        },
        "required": []
      }
    },
    {
      "name": "get_analytics",
      "description": "Get productivity analytics",
      "parameters": {
        "type": "object",
        "properties": {
          "period": {
            "type": "string"
          }
        },
        "required": []
      }
    },
    {
      "name": "update_settings",
      "description": "Update timer settings",
      "parameters": {
        "type": "object",
        "properties": {
          "work_duration": {
            "type": "integer"
          },
          "short_break": {
            "type": "integer"
          },
          "long_break": {
            "type": "integer"
          }
        },
        "required": []
      }
    },
    {
      "name": "start_break",
      "description": "Start a break timer",
      "parameters": {
        "type": "object",
        "properties": {
          "break_type": {
            "type": "string"
          },
          "custom_minutes": {
            "type": "integer"
          }
        },
        "required": []
      }
    }
  ]
}